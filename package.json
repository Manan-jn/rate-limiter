{
  "name": "rate-limiter-node",
  "version": "1.0.0",
  "description": "Production-grade distributed rate limiter — TypeScript, Fastify, Redis, Cluster mode",
  "type": "module",
  "main": "dist/cluster.js",
  "scripts": {
    "dev": "tsx watch src/cluster.ts",
    "build": "tsup",
    "start": "node dist/cluster.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.46.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "lru-cache": "^10.4.3",
    "opossum": "^8.1.4",
    "p-queue": "^8.0.1",
    "pino": "^9.4.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/opossum": "^8.1.7",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.10.3",
    "tsup": "^8.2.4",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
