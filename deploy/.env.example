# Required
REDIS_URL=redis://localhost:6379
PORT=8080

# Optional — defaults shown
WORKERS=4                        # Number of cluster workers (default: os.cpus().length)
ADMIN_TOKEN=change-me-in-prod    # Bearer token for admin API endpoints
CHECK_SECRET=change-me-in-prod   # HMAC-SHA256 secret for /api/v1/check SDK endpoint
FAIL_STRATEGY=open               # 'open' (allow) or 'closed' (503) when Redis is unreachable
LOG_LEVEL=info                   # trace | debug | info | warn | error
CONFIG_SYNC_INTERVAL_MS=30000    # Full config resync interval (pub/sub failsafe)
HOST=0.0.0.0                     # Bind address

# OTEL tracing (opt-in)
OTEL_EXPORTER_OTLP_ENDPOINT=https://tempo.grafana.net/otlp

# Memory tuning (important on containers with multiple workers)
NODE_OPTIONS=--max-old-space-size=256
